{
  "name": "career-document-studio",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "verify": "npm run verify:automation && npm run pdf:seed && npm run qa:static-pdf && npm run qa:print && npm run build",
    "verify:production": "npm run verify:automation && npm run qa:static-pdf && npm run qa:print && npm run build",
    "qa:print": "node scripts/qa-print-variations.mjs",
    "qa:static-pdf": "node scripts/qa-static-pdfs.mjs",
    "qa:ui": "node scripts/ui-smoke.mjs",
    "pdf:seed": "node scripts/seed-and-print.mjs resume && node scripts/seed-and-print.mjs cover",
    "verify:automation": "node scripts/verify-automation-surfaces.mjs",
    "deploy:mcgill-production": "zsh scripts/deploy-mcgill-production.sh"
  },
  "dependencies": {
    "@netlify/blobs": "10.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "netlify-cli": "^24.6.2",
    "postcss": "^8.4.47",
    "puppeteer-core": "^22.15.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^8.0.16"
  }
}
